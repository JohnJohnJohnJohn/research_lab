# Research Lab — environment variables
# Copy to .env and fill in values. Never commit .env.

# ── MODEL PROVIDER (pick one block; comment out others) ──────────

# Option A — DeepSeek
# DEEPSEEK_API_KEY=your_key_here                    # DeepSeek API key for chat completions
# LAB_MODEL_DIRECTOR=deepseek/deepseek-chat         # Model for Research Director
# LAB_MODEL_ANALYST=deepseek/deepseek-chat          # Default model for regional analysts
# LAB_MODEL_SPECIALIST=deepseek/deepseek-chat       # Default model for specialist sub-agents
# LAB_MODEL_COVERAGE=deepseek/deepseek-chat         # Default model for Coverage Agents

# Option B — Qwen via Dashscope (international endpoint; recommended for HK deployment and China A/H)
# DASHSCOPE_API_KEY=your_key_here                   # Alibaba Dashscope API key
# DASHSCOPE_API_BASE=https://dashscope-intl.aliyuncs.com/compatible-mode/v1  # OpenAI-compatible base URL
# LAB_MODEL_DIRECTOR=dashscope/qwen-max             # Model for Research Director
# LAB_MODEL_ANALYST=dashscope/qwen-max              # Default model for regional analysts
# LAB_MODEL_SPECIALIST=dashscope/qwen-plus          # Default model for specialist sub-agents
# LAB_MODEL_COVERAGE=dashscope/qwen-turbo           # Default model for Coverage Agents

# Option C — Anthropic (Claude)
# ANTHROPIC_API_KEY=your_key_here                   # Anthropic API key
# LAB_MODEL_DIRECTOR=claude-opus-4-5                # Model for Research Director
# LAB_MODEL_ANALYST=claude-sonnet-4-5               # Default model for regional analysts
# LAB_MODEL_SPECIALIST=claude-sonnet-4-5            # Default model for specialist sub-agents
# LAB_MODEL_COVERAGE=claude-haiku-3-5               # Default model for Coverage Agents

# ── PER-AGENT MODEL OVERRIDES (optional; override per-role) ───────
# LAB_MODEL_CN_ANALYST=dashscope/qwen-max           # China A/H regional analyst
# LAB_MODEL_HK_ANALYST=dashscope/qwen-plus          # HK regional analyst
# LAB_MODEL_US_ANALYST=claude-sonnet-4-5            # US regional analyst

# ── SLACK ─────────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=xoxb-your-token-here              # Bot User OAuth token for @director-bot
# SLACK_APP_TOKEN=xapp-your-token-here              # App-level token for Socket Mode (if used)
# SLACK_CHANNEL_ID=C0000000000                      # Channel ID for #research-lab

# ── DATA CAPABILITIES ─────────────────────────────────────────────
# Per-MCP vars also declared in mcp_servers/*/.env.example
# EODHD_API_KEY=your_key_here                         # Standard market data MCP (tier 2)
# BLOOMBERG_API_KEY=your_key_here                     # Premium institutional data MCP (tier 1; future)
